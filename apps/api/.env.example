# API server
PORT=3001
# Comma-separated allowed origins (CORS). On Vercel set this to your web URL,
# e.g. https://tarot-ai.vercel.app  (you can list several, comma-separated).
WEB_ORIGIN=http://localhost:3000

# Database
# Local Docker Postgres:
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tarot_ai
# Neon (Vercel Marketplace): use the POOLED connection string and require TLS.
#   DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
#   DATABASE_SSL=true
DATABASE_SSL=false
# Schema is owned by TypeORM migrations. On deploy, the Vercel build runs
# `db:deploy` (migration:run + seed) against this DATABASE_URL — so DATABASE_URL
# and DATABASE_SSL must be set in the Vercel project env (available at build).
# Locally `synchronize` builds the schema automatically; just run `pnpm seed`.

# Auth — signs the 7-day bearer tokens (register/login + the interpret gate).
# REQUIRED in the Vercel API project env; auth requests 503 without it.
JWT_SECRET=change-me
# Not used yet (no refresh tokens / Google OAuth) — reserved for later.
JWT_REFRESH_SECRET=change-me-too
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/auth/google/callback

# AI (Phase 4)
ANTHROPIC_API_KEY=
GOOGLE_AI_API_KEY=
